{
  "name": "one-million-hello-world",
  "version": "1.0.0",
  "description": "A Hello World HTTP server with 1 million lines of code across 25 architectural layers",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:dev": "ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:mutation": "stryker run",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "hello-world",
    "architecture",
    "typescript",
    "clean-architecture",
    "25-layers"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "@stryker-mutator/core": "^8.2.0",
    "@stryker-mutator/jest-runner": "^8.2.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "winston": "^3.11.0",
    "zod": "^3.22.4",
    "rxjs": "^7.8.1",
    "inversify": "^6.0.1",
    "reflect-metadata": "^0.2.1",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/sdk-trace-node": "^0.45.1",
    "@opentelemetry/auto-instrumentations-node": "^0.40.0",
    "@opentelemetry/exporter-trace-jaeger": "^1.18.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "uuid": "^9.0.0"
  }
}
